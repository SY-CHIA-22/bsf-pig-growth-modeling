fit_univariate_model <- function(var_name, data) {
  fm <- as.formula(paste("body_weight ~", var_name))
  mod <- lm(fm, data = data)
  
  tibble(
    predictor = var_name,
    r_squared = summary(mod)$r.squared,
    adj_r_squared = summary(mod)$adj.r.squared,
    rmse = sqrt(mean(residuals(mod)^2)),
    aic = AIC(mod),
    slope = coef(mod)[2],
    p_value = broom::tidy(mod)$p.value[2]
  )
}

univariate_results <- map_dfr(morpho_vars, fit_univariate_model, data = dat_model) %>%
  arrange(desc(adj_r_squared))

