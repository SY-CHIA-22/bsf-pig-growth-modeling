)

# Keep only formulas whose variables all exist in the data
formula_is_valid <- function(fm, data) {
  all(all.vars(fm) %in% names(data))
}

candidate_formulas <- candidate_formulas[
  map_lgl(candidate_formulas, formula_is_valid, data = dat_model)
]

fit_and_summarize_lm <- function(fm, model_name, data) {
  mod <- lm(fm, data = data)
  
  tibble(
    model = model_name,
    formula = deparse(fm),
    n = nobs(mod),
    r_squared = summary(mod)$r.squared,
    adj_r_squared = summary(mod)$adj.r.squared,
    rmse = sqrt(mean(residuals(mod)^2)),
    mae = mean(abs(residuals(mod))),
    aic = AIC(mod)
  )
}

model_comparison <- imap_dfr(candidate_formulas, ~fit_and_summarize_lm(.x, .y, dat_model)) %>%
  arrange(rmse, aic)

write_csv(model_comparison, file.path(tab_dir, "candidate_model_comparison.csv"))

# Save best model object
best_model_name <- model_comparison %>% slice(1) %>% pull(model)
best_lm <- lm(candidate_formulas[[best_model_name]], data = dat_model)

capture.output(summary(best_lm), file = file.path(tab_dir, "best_lm_summary.txt"))
