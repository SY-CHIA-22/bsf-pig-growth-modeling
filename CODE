  plot = p_sim_density,
  width = 9, height = 6, dpi = 300
)

# Plot mean and uncertainty intervals
p_sim_ci <- ggplot(sim_summary, aes(x = bsf_inclusion, y = mean_pred_bw)) +
  geom_line() +
  geom_point(size = 2) +
  geom_errorbar(aes(ymin = p2_5, ymax = p97_5), width = 3) +
  scale_x_continuous(breaks = sim_summary$bsf_inclusion) +
  labs(
