############################
# 15. K-fold cross-validation for candidate linear models
############################

set.seed(123)

# Create 5-fold cross-validation splits
folds <- rsample::vfold_cv(dat_model, v = 5)

cv_results <- map_dfr(names(candidate_formulas), function(model_name) {
  fm <- candidate_formulas[[model_name]]
  
  fold_metrics <- map_dfr(seq_along(folds$splits), function(i) {
    split <- folds$splits[[i]]
    train_dat <- analysis(split)
    test_dat  <- assessment(split)
    
    mod <- lm(fm, data = train_dat)
    preds <- predict(mod, newdata = test_dat)
    
    tibble(
      model = model_name,
      fold = i,
      rmse = yardstick::rmse_vec(truth = test_dat$body_weight, estimate = preds),
      mae  = yardstick::mae_vec(truth = test_dat$body_weight, estimate = preds),
      rsq  = yardstick::rsq_vec(truth = test_dat$body_weight, estimate = preds)
    )
  })
  
  fold_metrics
})

cv_summary <- cv_results %>%
  group_by(model) %>%
  summarise(
    cv_rmse = mean(rmse, na.rm = TRUE),
    cv_mae = mean(mae, na.rm = TRUE),
    cv_rsq = mean(rsq, na.rm = TRUE),
    .groups = "drop"
  ) %>%
  arrange(cv_rmse)

write_csv(cv_results, file.path(tab_dir, "cv_fold_results.csv"))
write_csv(cv_summary, file.path(tab_dir, "cv_summary.csv"))

