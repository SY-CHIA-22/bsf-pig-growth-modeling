# 20. Simulation-based forecasting
############################

# This section simulates expected BW across BSF inclusion levels
# using the best prediction model and observed variability in key
# morphometric traits.

set.seed(123)

# Select a model for simulation. Prefer a model with diet/inclusion
# if such a model is among candidate formulas. Otherwise use best_lm.
sim_model <- best_lm

# Define scenarios based on BSF inclusion levels
# Adjust these to match your real experimental levels
sim_scenarios <- tibble(
  scenario = c("0%", "25%", "50%", "75%", "100%"),
  bsf_inclusion = c(0, 25, 50, 75, 100)
)

# Build simulation template from observed morphometric distributions
# Here we use heart girth and body length if available
sim_n <- 5000

# Helper to simulate from empirical mean and SD
simulate_trait <- function(x, n) {
  mu <- mean(x, na.rm = TRUE)
  sd_x <- sd(x, na.rm = TRUE)
  rnorm(n, mean = mu, sd = sd_x)
}

# Create scenario-specific morphometric distributions if enough data exist
sim_data <- map_dfr(seq_len(nrow(sim_scenarios)), function(i) {
  
  incl <- sim_scenarios$bsf_inclusion[i]
  scen <- sim_scenarios$scenario[i]
  
  # If the observed dataset contains this inclusion level, use it;
  # otherwise use the whole dataset as a fallback.
  obs_sub <- dat_model %>%
    filter(!is.na(bsf_inclusion))
  
  if (incl %in% obs_sub$bsf_inclusion) {
    obs_sub <- obs_sub %>% filter(bsf_inclusion == incl)
  }
  
  if (nrow(obs_sub) < 5) {
    obs_sub <- dat_model
  }
  
  out <- tibble(
    scenario = scen,
    bsf_inclusion = incl,
    heart_girth = simulate_trait(obs_sub$heart_girth, sim_n),
    body_length = simulate_trait(obs_sub$body_length, sim_n)
  )
  
  # Add optional predictors if required by the chosen model
  if ("height_withers" %in% all.vars(formula(sim_model))) {
    if ("height_withers" %in% names(obs_sub)) {
      out$height_withers <- simulate_trait(obs_sub$height_withers, sim_n)
    } else {
      out$height_withers <- mean(dat_model$height_withers, na.rm = TRUE)
    }
  }
  
  # Add diet if required by the chosen model
  if ("diet" %in% all.vars(formula(sim_model))) {
    # Choose the most common diet label associated with this inclusion level if possible
    if ("diet" %in% names(obs_sub)) {
      top_diet <- obs_sub %>%
        count(diet, sort = TRUE) %>%
        slice(1) %>%
        pull(diet)
      out$diet <- factor(top_diet, levels = levels(dat_model$diet))
    } else {
      out$diet <- factor(levels(dat_model$diet)[1], levels = levels(dat_model$diet))
    }
  }
  
  out
})

# Predict simulated BW
sim_data$predicted_bw <- predict(sim_model, newdata = sim_data)

# Remove biologically impossible predictions
sim_data <- sim_data %>%
  filter(predicted_bw > 0)

# Summarize simulation output
sim_summary <- sim_data %>%
  group_by(scenario, bsf_inclusion) %>%
  summarise(
    mean_pred_bw = mean(predicted_bw, na.rm = TRUE),
    sd_pred_bw = sd(predicted_bw, na.rm = TRUE),
    p2_5 = quantile(predicted_bw, 0.025, na.rm = TRUE),
    p50 = quantile(predicted_bw, 0.50, na.rm = TRUE),
    p97_5 = quantile(predicted_bw, 0.975, na.rm = TRUE),
    .groups = "drop"
  )

write_csv(sim_summary, file.path(tab_dir, "simulation_summary.csv"))

# Plot simulation distributions
p_sim_density <- ggplot(sim_data, aes(x = predicted_bw, color = scenario)) +
  geom_density(linewidth = 1) +
  labs(
    title = "Simulated body weight distributions under BSF inclusion scenarios",
    x = "Predicted body weight",
    y = "Density"
  ) +
  theme_bw()

ggsave(
